{
  "name": "signalk-sun-moon",
  "version": "1.0.0",
  "description": "Webapp with sun & moon information (rise/set, phase, etc) based on vessel's position.",
  "author": "Zach Hoeken <hoeken@gmail.com>",
  "license": "Apache-2.0",
  "main": "index.js",
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-webapp",
    "signalk-category-utility",
    "sun",
    "moon",
    "astronomy",
    "suncalc"
  ],
  "signalk": {
    "displayName": "Sun & Moon",
    "appIcon": "icons/icon-512x512.png",
    "recommends": [
      "signalk-derived-data",
      "signalk-navico-embedder"
    ]
  },
  "signalk-plugin-enabled-by-default": true,
  "browserslist": "Chrome >= 69",
  "files": [
    "index.js",
    "server/",
    "openApi.json",
    "public/",
    "SPEC.md"
  ],
  "scripts": {
    "assets": "node scripts/gen-assets.cjs",
    "icons": "node scripts/gen-icons.mjs",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "suncalc": "^2.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "esbuild": "^0.28.1",
    "jsdom": "^25.0.1",
    "png-to-ico": "^3.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sharp": "^0.35.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hoeken/signalk-sun-moon.git"
  }
}
{
  "name": "signalk-sun-moon",
  "version": "1.0.2",
  "description": "Webapp with sun & moon information (rise/set, phase, etc) based on vessel's position.",
  "author": "Zach Hoeken <hoeken@gmail.com>",
  "license": "Apache-2.0",
  "main": "index.js",
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-webapp",
    "signalk-category-utility",
    "sun",
    "moon",
    "astronomy",
    "suncalc"
  ],
  "signalk": {
    "displayName": "Sun & Moon",
    "appIcon": "icons/icon-512x512.png",
    "screenshots": [
      "./docs/screenshots/day-mode.png",
      "./docs/screenshots/night-mode.png"
    ],
    "recommends": [
      "signalk-derived-data",
      "signalk-navico-embedder"
    ]
  },
  "signalk-plugin-enabled-by-default": true,
  "browserslist": "Chrome >= 69",
  "files": [
    "index.js",
    "server/",
    "docs/screenshots",
    "openApi.json",
    "public/",
    "SPEC.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "release": "git tag -d v$npm_package_version; git tag v$npm_package_version && git push && git push origin v$npm_package_version",
    "assets": "node scripts/gen-assets.cjs",
    "icons": "node scripts/gen-icons.mjs",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "eslint --fix . && prettier --write .",
    "format:check": "eslint . && prettier --check .",
    "prepare": "husky || true",
    "prepublishOnly": "npm run build"
  },
  "lint-staged": {
    "*.{js,jsx,cjs,mjs}": "eslint --fix",
    "*.{json,css,html}": "prettier --write"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "suncalc": "^2.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@vitejs/plugin-react": "^6.0.3",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^16.4.0",
    "png-to-ico": "^3.0.1",
    "prettier": "^3.8.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sharp": "^0.35.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hoeken/signalk-sun-moon.git"
  }
}

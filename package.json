{
  "name": "signalk-sun-moon",
  "version": "1.0.0",
  "description": "Signal K plugin + webapp showing clean sun & moon information (rise/set, phase, observer-oriented moon) for the vessel's position and a chosen day.",
  "author": "Zach Hoeken <hoeken@gmail.com>",
  "license": "Apache-2.0",
  "main": "index.js",
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-webapp",
    "sun",
    "moon",
    "astronomy",
    "suncalc"
  ],
  "signalk": {
    "displayName": "Sun & Moon",
    "appIcon": "./public/icons/icon-72x72.png"
  },
  "browserslist": "Chrome >= 69",
  "files": [
    "index.js",
    "server/",
    "openApi.json",
    "public/",
    "SPEC.md"
  ],
  "scripts": {
    "assets": "node scripts/gen-assets.cjs",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "suncalc": "^2.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^5.4.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hoeken/signalk-sun-moon.git"
  }
}
